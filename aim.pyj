def TriggerAim(key):
    global aim
    global lastTick 
    if key.key == 88:
        if key.action == 0:
            if aim == 0:
                lastTick = player.tickCount
                aim = 1
                echo("starting", aim)
            else:
                aim = 0
                echo("setting aim 0")

add_event_listener("key", TriggerAim)
add_event_listener("tick", getTarget)
add_event_listener("render", AimAssist)